### Linux ###
.*
!.gitignore
!.gitattributes
!.github
*~
#############

### OpenMRS Files ###
/webapp/activemq-data
/webapp/src/main/webapp/WEB-INF/tags/module
/webapp/src/main/webapp/WEB-INF/dwr-modules.xml
/webapp/src/main/webapp/WEB-INF/module_messages*
#############

!omod/src/main/webapp/resources/js/swagger-ui/*

### Lucene Indices from Tests ###
/omod-*/org.openmrs.*/*

# Local environment files (never commit real credentials)
.env

