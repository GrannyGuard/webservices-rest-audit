                </mxCell>
                <mxCell id="boundary_module" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;REST Web Services Module (.omod)&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[Container: Java, Spring MVC]&lt;/div&gt;" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#666666;fontColor=#333333;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="280" width="1430" height="837" as="geometry"/>
                </mxCell>
                <mxCell id="c_contenttype" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;ContentTypeFilter&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Servlet Filter]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Validates/normalises Content-Type and Accept headers for requests under /ws/rest/*; first module filter in the chain&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="110" y="370" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_authfilter" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;AuthorizationFilter&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Servlet Filter]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Blocks disallowed remote IPs (RestUtil.isIpAllowed) and authenticates &amp;#39;Authorization: Basic&amp;#39; headers via Context.authenticate before passing the request on&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="450" y="370" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_mainresourcecontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;MainResourceController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Generic dispatcher mapping /ws/rest/v1/{resource}[/{uuid}] requests to the matching Resource implementation&amp;#39;s CRUD operation&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="790" y="370" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_baserestcontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;BaseRestController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Shared base controller; @ExceptionHandler methods translate ResponseException subclasses into HTTP status codes and error bodies&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="1130" y="370" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_resourceframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Resource Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java &amp;#8212; ~109 implementations]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;BaseDelegatingResource / DelegatingCrudResource and the Resource/CrudResource/Searchable/Creatable/... API that ~109 concrete resources implement to map OpenMRS domain objects to REST operations&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="94" y="543" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_representationframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Representation Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Representation hierarchy (Ref/Default/Full/Custom/Named), @PropertyGetter/@PropertySetter/@RepHandler annotations and ConversionUtil/DelegatingConverter; controls which fields are (de)serialised&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="434" y="543" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_searchhandlerframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SearchHandler Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;SearchHandler/SubResourceSearchHandler, SearchConfig and SearchQuery; lets resources declare pluggable, parameterised search behaviour&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="774" y="543" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_responseexceptions" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Response / Exception Hierarchy&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;ResponseException subclasses &amp;#8212; ObjectNotFoundException, ConversionException, IllegalRequestException, GenericRestException, SuccessfulDeletion, ... &amp;#8212; thrown by resources on error/success conditions&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="1114" y="543" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_swaggerspeccreator" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SwaggerSpecificationCreator&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Introspects every registered resource, its representations and search handlers to build an OpenAPI/Swagger 2.0 specification document&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="101" y="765" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_swaggercontrollers" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Swagger Controllers&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controllers]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;SwaggerDocController and SwaggerSpecificationController serve the interactive API docs UI and the generated OpenAPI JSON spec&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="441" y="765" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_settingsformcontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SettingsFormController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Renders and persists the module&amp;#39;s admin settings page at /module/webservices/rest/settings.form (allowed IPs, max-result limits, Swagger logging)&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="781" y="765" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_versioncontrollers" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Version-Specific Controllers&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controllers]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Endpoints outside the generic resource model, grouped per OpenMRS version &amp;#8212; SessionController (incl. /session/diag), ChangePasswordController, PasswordResetController, HL7MessageController, ClearDbCacheController, ...&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
                    <mxGeometry x="1121" y="765" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_restutil" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;RestUtil &amp;amp; RestConstants&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java utility classes]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Shared helpers &amp;#8212; isIpAllowed() IP/CIDR matching, privilege names (Manage/View RESTWS, Set Audit Data), URI prefixes and default paging limits&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
