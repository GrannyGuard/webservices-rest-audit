                </mxCell>
                <mxCell id="ext_openmrs_webapp" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;OpenMRS Web Application&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Java, Spring, Apache Tomcat]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;Hosting application providing core domain services, security context (Context) and persistence &amp;#8212; see the C4 Level 2 Container diagram&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;labelBackgroundColor=none;fillColor=#1061B0;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0D5091;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" parent="1" vertex="1">
