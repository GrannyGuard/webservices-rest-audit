<mxfile host="app.diagrams.net" version="24.0.0" type="device">
  <diagram name="C4 - Level 3 - Components (REST Web Services Module)" id="c4-level3-component">
    <mxGraphModel dx="800" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1580" pageHeight="1340" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="C4 Model - Level 3: Component Diagram&lt;br&gt;REST Web Services Module (.omod)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- External actors -->
        <mxCell id="p_developer" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Integration Developer&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Person]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#cccccc&quot;&gt;Builds client applications and reads the generated API docs&lt;/font&gt;&lt;/div&gt;" style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#083F75;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];resizable=0;" vertex="1" parent="1">
          <mxGeometry x="110" y="110" width="210" height="150" as="geometry" />
        </mxCell>

        <mxCell id="p_admin" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;System Administrator&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Person]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#cccccc&quot;&gt;Configures module settings via the contributed admin page&lt;/font&gt;&lt;/div&gt;" style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#083F75;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];resizable=0;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="210" height="150" as="geometry" />
        </mxCell>

        <mxCell id="ext_client_app" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Third-Party Client Application&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Software System]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#cccccc&quot;&gt;Sends authenticated REST/JSON requests over HTTPS&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#8C8496;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#736782;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="660" y="120" width="250" height="140" as="geometry" />
        </mxCell>

        <!-- Container boundary -->
        <mxCell id="boundary_module" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;REST Web Services Module (.omod)&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[Container: Java, Spring MVC]&lt;/div&gt;" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#666666;fontColor=#333333;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="1430" height="760" as="geometry" />
        </mxCell>

        <!-- Row 1: entry & dispatch -->
        <mxCell id="c_contenttype" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;ContentTypeFilter&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Servlet Filter]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Validates/normalises Content-Type and Accept headers for requests under /ws/rest/*; first module filter in the chain&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="110" y="370" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_authfilter" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;AuthorizationFilter&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Servlet Filter]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Blocks disallowed remote IPs (RestUtil.isIpAllowed) and authenticates &amp;#39;Authorization: Basic&amp;#39; headers via Context.authenticate before passing the request on&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="450" y="370" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_mainresourcecontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;MainResourceController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Generic dispatcher mapping /ws/rest/v1/{resource}[/{uuid}] requests to the matching Resource implementation&amp;#39;s CRUD operation&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="790" y="370" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_baserestcontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;BaseRestController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Shared base controller; @ExceptionHandler methods translate ResponseException subclasses into HTTP status codes and error bodies&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="1130" y="370" width="300" height="130" as="geometry" />
        </mxCell>

        <!-- Row 2: domain & representation framework -->
        <mxCell id="c_resourceframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Resource Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java &amp;#8212; ~109 implementations]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;BaseDelegatingResource / DelegatingCrudResource and the Resource/CrudResource/Searchable/Creatable/... API that ~109 concrete resources implement to map OpenMRS domain objects to REST operations&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="110" y="530" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_representationframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Representation Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Representation hierarchy (Ref/Default/Full/Custom/Named), @PropertyGetter/@PropertySetter/@RepHandler annotations and ConversionUtil/DelegatingConverter; controls which fields are (de)serialised&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="450" y="530" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_searchhandlerframework" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SearchHandler Framework&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;SearchHandler/SubResourceSearchHandler, SearchConfig and SearchQuery; lets resources declare pluggable, parameterised search behaviour&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="790" y="530" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_responseexceptions" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Response / Exception Hierarchy&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;ResponseException subclasses &amp;#8212; ObjectNotFoundException, ConversionException, IllegalRequestException, GenericRestException, SuccessfulDeletion, ... &amp;#8212; thrown by resources on error/success conditions&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="1130" y="530" width="300" height="130" as="geometry" />
        </mxCell>

        <!-- Row 3: documentation & admin -->
        <mxCell id="c_swaggerspeccreator" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SwaggerSpecificationCreator&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Introspects every registered resource, its representations and search handlers to build an OpenAPI/Swagger 2.0 specification document&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="110" y="690" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_swaggercontrollers" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Swagger Controllers&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controllers]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;SwaggerDocController and SwaggerSpecificationController serve the interactive API docs UI and the generated OpenAPI JSON spec&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="450" y="690" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_settingsformcontroller" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;SettingsFormController&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controller]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Renders and persists the module&amp;#39;s admin settings page at /module/webservices/rest/settings.form (allowed IPs, max-result limits, Swagger logging)&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="790" y="690" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="c_versioncontrollers" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;Version-Specific Controllers&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Spring MVC Controllers]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Endpoints outside the generic resource model, grouped per OpenMRS version &amp;#8212; SessionController (incl. /session/diag), ChangePasswordController, PasswordResetController, HL7MessageController, ClearDbCacheController, ...&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="1130" y="690" width="300" height="130" as="geometry" />
        </mxCell>

        <!-- Row 4: shared utilities -->
        <mxCell id="c_restutil" value="&lt;font style=&quot;font-size: 15px&quot;&gt;&lt;b&gt;RestUtil &amp;amp; RestConstants&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Component: Java utility classes]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Shared helpers &amp;#8212; isIpAllowed() IP/CIDR matching, privilege names (Manage/View RESTWS, Set Audit Data), URI prefixes and default paging limits&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#63BEF2;fontColor=#ffffff;align=center;arcSize=6;strokeColor=#2086C9;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="110" y="850" width="300" height="130" as="geometry" />
        </mxCell>

        <!-- External dependency -->
        <mxCell id="ext_openmrs_webapp" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;OpenMRS Web Application&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Java, Spring, Apache Tomcat]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;Hosting application providing core domain services, security context (Context) and persistence &amp;#8212; see the C4 Level 2 Container diagram&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;labelBackgroundColor=none;fillColor=#1061B0;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0D5091;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
          <mxGeometry x="625" y="1100" width="320" height="160" as="geometry" />
        </mxCell>

        <!-- Relationships -->
        <mxCell id="r1" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Sends REST requests&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center&quot;&gt;[HTTPS, JSON]&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="ext_client_app" target="c_contenttype">
          <mxGeometry width="240" relative="1" as="geometry"><mxPoint as="sourcePoint" /><mxPoint as="targetPoint" /></mxGeometry>
        </mxCell>

        <mxCell id="r2" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Browses interactive API documentation&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center&quot;&gt;[HTTPS]&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p_developer" target="c_swaggercontrollers">
          <mxGeometry width="240" relative="1" as="geometry"><mxPoint as="sourcePoint" /><mxPoint as="targetPoint" /></mxGeometry>
        </mxCell>

        <mxCell id="r3" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Configures module settings&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center&quot;&gt;[HTTPS]&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p_admin" target="c_settingsformcontroller">
          <mxGeometry width="240" relative="1" as="geometry"><mxPoint as="sourcePoint" /><mxPoint as="targetPoint" /></mxGeometry>
        </mxCell>

        <mxCell id="r4" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Forwards request down the filter chain&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center&quot;&gt;[Servlet FilterChain]&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_contenttype" target="c_authfilter">
          <mxGeometry width="240" relative="1" as="geometry"><mxPoint as="sourcePoint" /><mxPoint as="targetPoint" /></mxGeometry>
        </mxCell>

        <mxCell id="r5" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Forwards authenticated request to the dispatcher&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center&quot;&gt;[Servlet FilterChain]&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_authfilter" target="c_mainresourcecontroller">
          <mxGeometry width="240" relative="1" as="geometry"><mxPoint as="sourcePoint" /><mxPoint as="targetPoint" /></mxGeometry>
        </mxCell>

        <mxCell id="r6" value="&lt;div style=&quot;text-align: center&quot;&gt;&lt;b&gt;Inherits shared request handling and exception translation&lt;/b&gt;&lt;/div&gt;" style="endArrow=blockThin;html=1;fontSize=10;fontColor=#404040;strokeWidth=1;endFill=1;strokeColor=#828282;elbow=vertical;metaEdit=1;endSize=14;startSize=14;jumpStyle=arc;jumpSize=16;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_mainresourcecontroller" target="c_baserestcontroller">
